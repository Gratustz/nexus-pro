# ============================================
# NEXUS PRO — ENVIRONMENT VARIABLES
# ============================================

# --- APP ---
APP_NAME=Nexus Pro
APP_ENV=development
DEBUG=True
SECRET_KEY=nexuspro-secret-change-this-in-production

# --- DATABASE ---
DATABASE_URL=sqlite:///./nexuspro.db

# --- JWT AUTH ---
JWT_SECRET_KEY=nexuspro-jwt-secret-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- BINANCE (Crypto) ---
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# --- ALPHA VANTAGE (Forex) ---
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# --- AI SIGNAL LAYER ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- CORS ---
FRONTEND_URL=http://localhost:3000

# --- SCHEDULER ---
CRYPTO_INTERVAL_SECONDS=60
FOREX_INTERVAL_SECONDS=300
SPORTS_INTERVAL_SECONDS=1800
